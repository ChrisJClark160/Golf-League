# Copy this file to .env and fill in the values
# Do NOT commit .env to git — it's in .gitignore

# -------------------------------------------------------------------
# Your public domain — what Caddy will request a cert for
# -------------------------------------------------------------------
DOMAIN=golf.pibooks.me

# -------------------------------------------------------------------
# Caddy basic-auth credential for the /_/ PocketBase admin path
# Generate with: docker run --rm caddy:2-alpine caddy hash-password
# Paste the resulting hash here, including the $2a$... prefix
# Note: escape any literal $ as $$ in docker compose env files
# -------------------------------------------------------------------
ADMIN_BASIC_AUTH=$$2a$$14$$replaceThisWithRealHashFromCaddyHashPasswordCommand

# -------------------------------------------------------------------
# Timezone for cron and timestamps
# -------------------------------------------------------------------
TZ=Europe/London

# -------------------------------------------------------------------
# SMTP — used by PocketBase for password resets and notifications
# Configure these via PocketBase admin UI after first login
# Not consumed by docker compose, listed here for reference
# -------------------------------------------------------------------
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_xxxxxxxxxxxx
# SMTP_FROM=golf@pibooks.me

# -------------------------------------------------------------------
# UK Golf Course API — Phase 4 feature
# Sign up: https://rapidapi.com/raznut303/api/uk-golf-course-data-api
# Free tier: 200 req/month, 5 req/min — plenty for this league
# -------------------------------------------------------------------
# UK_GOLF_API_KEY=your-rapidapi-key-here
