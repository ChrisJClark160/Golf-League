# Secrets
.env
.env.local
.env.production

# PocketBase data (database, sessions, uploads)
pocketbase/pb_data/
!pocketbase/pb_data/.gitkeep

# Backups (we never want these in git)
backups/
!backups/.gitkeep

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor folders
.vscode/
.idea/
*.swp
*.swo

# Node (if frontend grows to need it)
node_modules/
dist/
.next/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Caddy data — managed by Docker volumes, not committed
caddy_data/
caddy_config/
